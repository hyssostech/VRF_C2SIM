<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
  </PropertyGroup>
  <ItemGroup>
    <!-- Shared argument-handling helpers (usage/exit-code standard). Pure managed: linking
         it in adds NOTHING to the con-selftest path's dependency surface. -->
    <Compile Include="..\Shared\ToolArgs.cs" Link="ToolArgs.cs" />
  </ItemGroup>
  <ItemGroup>
    <!-- The C++/CLI bridge (native VR-Forces control). CopyLocal drops VrfBridge.dll
         beside the exe. WatchVrf needs NO C2SIM SDK - it is pure VR-Forces. -->
    <Reference Include="VrfBridge">
      <HintPath>..\..\src\VrfBridge\build\Release\VrfBridge.dll</HintPath>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <!-- IJW bootstrap: required next to the consumer exe for a /clr:netcore assembly.
         A bare <Reference> does NOT copy it (PORT.md sec 3), so copy it explicitly. -->
    <None Include="..\..\src\VrfBridge\build\Release\Ijwhost.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
